{
  "mcpServers": {
    "apollo": {
      "type": "http",
      "url": "https://mcp.apollo.io/mcp"
    },
    "clay": {
      "type": "http",
      "url": "https://api.clay.com/v3/mcp"
    },
    "close": {
      "type": "http",
      "url": "https://mcp.close.com/mcp"
    },
    "hubspot": {
      "type": "http",
      "url": "https://mcp.hubspot.com/anthropic"
    },
    "lark": {
      "type": "http",
      "url": "${LARK_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${LARK_MCP_BEARER_TOKEN}"
      }
    },
    "outreach": {
      "type": "http",
      "url": "https://api.outreach.io/mcp/"
    },
    "similarweb": {
      "type": "http",
      "url": "https://mcp.similarweb.com/mcp"
    },
    "zoominfo": {
      "type": "http",
      "url": "https://mcp.zoominfo.com/mcp"
    }
  }
}
