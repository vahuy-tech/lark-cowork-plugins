{
  "mcpServers": {
    "datadog": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "lark": {
      "type": "http",
      "url": "${LARK_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${LARK_MCP_BEARER_TOKEN}"
      }
    },
    "pagerduty": {
      "type": "http",
      "url": "https://mcp.pagerduty.com/mcp"
    }
  }
}
